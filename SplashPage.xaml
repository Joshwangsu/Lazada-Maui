<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lazada.SplashPage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#7B1FA2" Offset="0.1" />
            <GradientStop Color="#F50057" Offset="0.6" />
            <GradientStop Color="#FF80AB" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
            <Image Source="lazada_logo.png" 
                   WidthRequest="180" 
                   HeightRequest="180" 
                   HorizontalOptions="Center" />
            
        </VerticalStackLayout>

        <ActivityIndicator IsRunning="True" 
                           Color="White" 
                           HorizontalOptions="Center" 
                           VerticalOptions="End"
                           Margin="0,0,0,100" />
    </Grid>
</ContentPage>
