<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lazada.ProductDetailPage"
             Title="Product Details">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">
                <!-- Product Image -->
                <BoxView Color="#E0E0E0" HeightRequest="400" />
                
                <VerticalStackLayout Padding="15" Spacing="10" BackgroundColor="White">
                    <Label Text="₱ 299" TextColor="#F57224" FontSize="28" FontAttributes="Bold" />
                    <Label Text="Wireless Earbuds Bluetooth 5.0 with Noise Cancellation and Charging Case" 
                           FontSize="18" LineBreakMode="WordWrap" />
                    
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <Label Text="⭐ 4.9" TextColor="#F57224" FontSize="14" />
                        <Label Text="124 Ratings" TextColor="Gray" FontSize="14" />
                        <Label Text="|" TextColor="LightGray" />
                        <Label Text="10k+ Sold" TextColor="Gray" FontSize="14" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Shipping -->
                <Frame Margin="0,10,0,0" Padding="15" BackgroundColor="White" HasShadow="False">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Label Text="🚚" FontSize="20" VerticalOptions="Center" Margin="0,0,10,0" />
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Standard Delivery" FontAttributes="Bold" />
                            <Label Text="Get it by May 15 - May 18" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="₱ 45" VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- Store Info -->
                <Frame Margin="0,10,0,0" Padding="15" BackgroundColor="White" HasShadow="False">
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                        <Frame HeightRequest="50" WidthRequest="50" CornerRadius="25" Padding="0" HasShadow="False">
                            <BoxView Color="#F57224" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Lazada Official Store" FontAttributes="Bold" />
                            <Label Text="98% Positive Feedback" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="Visit Store" FontSize="12" HeightRequest="35" Padding="10,0" BackgroundColor="White" TextColor="#F57224" BorderColor="#F57224" BorderWidth="1" />
                    </Grid>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, *" Padding="10" BackgroundColor="White" ColumnSpacing="10">
            <VerticalStackLayout VerticalOptions="Center" Padding="10,0">
                <Label Text="💬" FontSize="20" HorizontalOptions="Center" />
                <Label Text="Chat" FontSize="10" HorizontalOptions="Center" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="Add to Cart" BackgroundColor="#FF9900" TextColor="White" CornerRadius="5" />
            <Button Grid.Column="2" Text="Buy Now" BackgroundColor="#F57224" TextColor="White" CornerRadius="5" />
        </Grid>
    </Grid>
</ContentPage>
