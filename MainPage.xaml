<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lazada.MainPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource LazadaCanvas}">

    <Grid RowDefinitions="Auto, *, Auto" BackgroundColor="White">
        
        <!-- 1. Sticky Header Section -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="White" Padding="0,0,0,5">
            <!-- Search Bar Area -->
            <Grid ColumnDefinitions="*, Auto" Padding="15,40,15,10" ColumnSpacing="12">
                <Border Grid.Column="0" Stroke="{StaticResource LazadaBrand}" StrokeThickness="1.5" HeightRequest="40" BackgroundColor="{StaticResource LazadaSurface}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="15,0">
                        <Path Data="{StaticResource IconSearch}" Fill="{StaticResource LazadaTextSecondary}" HeightRequest="16" WidthRequest="16" Aspect="Uniform" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Search on Lazada" Margin="10,0" VerticalOptions="Center" TextColor="{StaticResource LazadaTextSecondary}" FontSize="14" />
                        <Path Grid.Column="2" Data="{StaticResource IconSettings}" Fill="{StaticResource LazadaTextSecondary}" HeightRequest="16" WidthRequest="16" Aspect="Uniform" VerticalOptions="Center" />
                    </Grid>
                </Border>
                <HorizontalStackLayout Grid.Column="1" Spacing="15" VerticalOptions="Center">
                    <Path Data="{StaticResource IconVoucher}" Fill="{StaticResource LazadaTextSecondary}" HeightRequest="22" WidthRequest="22" Aspect="Uniform" />
                    <Path Data="{StaticResource IconCart}" Fill="{StaticResource LazadaTextSecondary}" HeightRequest="22" WidthRequest="22" Aspect="Uniform" />
                </HorizontalStackLayout>
            </Grid>
        </VerticalStackLayout>

        <!-- 2. Scrollable Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">
                
                <!-- Hero Banner Carousel (Simplified for UI Demo) -->
                <Grid HeightRequest="180" Margin="15,0">
                    <Border StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                        <Image Source="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?w=800" Aspect="AspectFill" />
                    </Border>
                    <!-- Indicators Placeholder -->
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,10" Spacing="5">
                        <Ellipse WidthRequest="6" HeightRequest="6" Fill="White" />
                        <Ellipse WidthRequest="6" HeightRequest="6" Fill="#80FFFFFF" />
                        <Ellipse WidthRequest="6" HeightRequest="6" Fill="#80FFFFFF" />
                    </HorizontalStackLayout>
                </Grid>

                <!-- Service Icons Bar -->
                <Grid ColumnDefinitions="*, *, *, *, *" Padding="10,20" HorizontalOptions="Fill">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="8">
                        <Border HeightRequest="45" WidthRequest="45" StrokeThickness="0" BackgroundColor="#FFF8E1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="15" /></Border.StrokeShape>
                            <Path Data="{StaticResource IconCoin}" Fill="#FFC107" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="20" WidthRequest="20" />
                        </Border>
                        <Label Text="Coins" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource LazadaTextPrimary}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="8">
                        <Border HeightRequest="45" WidthRequest="45" StrokeThickness="0" BackgroundColor="#E1F5FE">
                            <Border.StrokeShape><RoundRectangle CornerRadius="15" /></Border.StrokeShape>
                            <Path Data="{StaticResource IconLive}" Fill="#03A9F4" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="20" WidthRequest="20" />
                        </Border>
                        <Label Text="LazLive" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource LazadaTextPrimary}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="8">
                        <Border HeightRequest="45" WidthRequest="45" StrokeThickness="0" BackgroundColor="#E8F5E9">
                            <Border.StrokeShape><RoundRectangle CornerRadius="15" /></Border.StrokeShape>
                            <Path Data="{StaticResource IconCart}" Fill="#4CAF50" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="20" WidthRequest="20" />
                        </Border>
                        <Label Text="LazMart" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource LazadaTextPrimary}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="8">
                        <Border HeightRequest="45" WidthRequest="45" StrokeThickness="0" BackgroundColor="#FFF3E0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="15" /></Border.StrokeShape>
                            <Path Data="{StaticResource IconTree}" Fill="#FF9800" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="20" WidthRequest="20" />
                        </Border>
                        <Label Text="LazLand" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource LazadaTextPrimary}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="8">
                        <Border HeightRequest="45" WidthRequest="45" StrokeThickness="0" BackgroundColor="#F3E5F5">
                            <Border.StrokeShape><RoundRectangle CornerRadius="15" /></Border.StrokeShape>
                            <Path Data="{StaticResource IconStar}" Fill="#9C27B0" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="20" WidthRequest="20" />
                        </Border>
                        <Label Text="BigWin+" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource LazadaTextPrimary}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Flash Sale Section -->
                <Border Margin="15,0" Padding="15" BackgroundColor="White" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Label Text="Flash Sale" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource LazadaTextPrimary}" />
                                <Border BackgroundColor="{StaticResource LazadaBrand}" Padding="6,2" StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                                    <Label Text="00:12:45" FontSize="12" TextColor="White" FontAttributes="Bold" />
                                </Border>
                            </HorizontalStackLayout>
                            <Label Grid.Column="1" Text="See All >" TextColor="{StaticResource LazadaBrand}" FontSize="13" VerticalOptions="Center" />
                        </Grid>

                        <CollectionView ItemsSource="{Binding FlashSaleProducts}" HeightRequest="160">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout WidthRequest="100" Spacing="6">
                                        <Border HeightRequest="100" WidthRequest="100" StrokeThickness="0" BackgroundColor="#F8F9FA">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        </Border>
                                        <Label Text="{Binding Price, StringFormat='₱{0}'}" TextColor="{StaticResource LazadaBrand}" FontAttributes="Bold" FontSize="15" HorizontalOptions="Center" />
                                        <Border HeightRequest="4" BackgroundColor="#EEEEEE" WidthRequest="80" HorizontalOptions="Center">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="2" /></Border.StrokeShape>
                                            <BoxView BackgroundColor="{StaticResource LazadaBrand}" WidthRequest="60" HorizontalOptions="Start" />
                                        </Border>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Recommendation Feed Title -->
                <Label Text="Just For You" FontSize="18" FontAttributes="Bold" Margin="15,25,15,10" TextColor="{StaticResource LazadaTextPrimary}" />

                <!-- Product Grid -->
                <CollectionView ItemsSource="{Binding Products}" Margin="10,0">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" StrokeThickness="0" SelectionChanged="OnProductSelected">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnProductTapped" /></Border.GestureRecognizers>
                                <VerticalStackLayout>
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="180" />
                                    <VerticalStackLayout Padding="10" Spacing="5">
                                        <Label Text="{Binding Name}" FontSize="13" MaxLines="2" LineBreakMode="TailTruncation" TextColor="{StaticResource LazadaTextPrimary}" />
                                        <Label Text="{Binding Price, StringFormat='₱{0:N2}'}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource LazadaBrand}" />
                                        <HorizontalStackLayout Spacing="4">
                                            <Path Data="{StaticResource IconStar}" Fill="#FFC107" WidthRequest="10" HeightRequest="10" VerticalOptions="Center" />
                                            <Label Text="{Binding Rating}" FontSize="10" TextColor="{StaticResource LazadaTextSecondary}" />
                                            <Label Text="|" TextColor="#EEEEEE" />
                                            <Label Text="{Binding SoldCount, StringFormat='{0} sold'}" FontSize="10" TextColor="{StaticResource LazadaTextSecondary}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                
                <BoxView HeightRequest="20" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- 3. Sticky Bottom Navigation Bar -->
        <Grid Grid.Row="2" ColumnDefinitions="*, *, *, *, *" HeightRequest="65" BackgroundColor="White">
            <Grid.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="10" Opacity="0.05" />
            </Grid.Shadow>
            
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                <Path Data="{StaticResource IconHome}" Fill="{StaticResource LazadaBrand}" WidthRequest="22" HeightRequest="22" Aspect="Uniform" />
                <Label Text="Home" FontSize="11" TextColor="{StaticResource LazadaBrand}" FontAttributes="Bold" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers><TapGestureRecognizer Tapped="OnLazMallTapped" /></VerticalStackLayout.GestureRecognizers>
                <Path Data="{StaticResource IconLazMall}" Fill="{StaticResource LazadaTextSecondary}" WidthRequest="22" HeightRequest="22" Aspect="Uniform" />
                <Label Text="LazMall" FontSize="11" TextColor="{StaticResource LazadaTextSecondary}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers><TapGestureRecognizer Tapped="OnMessageTapped" /></VerticalStackLayout.GestureRecognizers>
                <Path Data="{StaticResource IconMessageBubble}" Fill="{StaticResource LazadaTextSecondary}" WidthRequest="22" HeightRequest="22" Aspect="Uniform" />
                <Label Text="Message+" FontSize="11" TextColor="{StaticResource LazadaTextSecondary}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers><TapGestureRecognizer Tapped="OnCartTapped" /></VerticalStackLayout.GestureRecognizers>
                <Path Data="{StaticResource IconCart}" Fill="{StaticResource LazadaTextSecondary}" WidthRequest="22" HeightRequest="22" Aspect="Uniform" />
                <Label Text="Cart" FontSize="11" TextColor="{StaticResource LazadaTextSecondary}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers><TapGestureRecognizer Tapped="OnAccountTapped" /></VerticalStackLayout.GestureRecognizers>
                <Path Data="{StaticResource IconAccount}" Fill="{StaticResource LazadaTextSecondary}" WidthRequest="22" HeightRequest="22" Aspect="Uniform" />
                <Label Text="Account" FontSize="11" TextColor="{StaticResource LazadaTextSecondary}" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
