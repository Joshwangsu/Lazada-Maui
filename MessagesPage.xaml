<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lazada.MessagesPage"
             Title="Messages"
             BackgroundColor="#F2F2F2">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="White" Padding="15,10" ColumnDefinitions="*, Auto">
            <Label Text="Messages" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="⚙️" FontSize="20" VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="0,10" Spacing="1">
                <!-- Chat Item 1 -->
                <Grid BackgroundColor="White" Padding="15" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                    <Frame HeightRequest="50" WidthRequest="50" CornerRadius="25" Padding="0" HasShadow="False" BackgroundColor="#F50057">
                        <Label Text="L" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" />
                    </Frame>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Lazada Official Store" FontAttributes="Bold" FontSize="14" />
                        <Label Text="Your order #123456 has been shipped!" FontSize="12" TextColor="Gray" MaxLines="1" LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="14:30" FontSize="10" TextColor="Gray" VerticalOptions="Start" />
                </Grid>

                <!-- Chat Item 2 -->
                <Grid BackgroundColor="White" Padding="15" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                    <Frame HeightRequest="50" WidthRequest="50" CornerRadius="25" Padding="0" HasShadow="False" BackgroundColor="#4CAF50">
                        <Label Text="S" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" />
                    </Frame>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Samsung Official" FontAttributes="Bold" FontSize="14" />
                        <Label Text="Hi! How can we help you today?" FontSize="12" TextColor="Gray" MaxLines="1" LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="Yesterday" FontSize="10" TextColor="Gray" VerticalOptions="Start" />
                </Grid>

                <!-- Chat Item 3 -->
                <Grid BackgroundColor="White" Padding="15" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                    <Frame HeightRequest="50" WidthRequest="50" CornerRadius="25" Padding="0" HasShadow="False" BackgroundColor="#2196F3">
                        <Label Text="N" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" />
                    </Frame>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Nike Store" FontAttributes="Bold" FontSize="14" />
                        <Label Text="Check out our new arrivals!" FontSize="12" TextColor="Gray" MaxLines="1" LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="Monday" FontSize="10" TextColor="Gray" VerticalOptions="Start" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
