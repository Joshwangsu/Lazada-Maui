<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Design Tokens - Anti-Generic UI Enforcement -->
    
    <!-- Colors -->
    <Color x:Key="LazadaBrand">#F0134D</Color>
    <Color x:Key="LazadaBrandLight">#FFF0F3</Color>
    <Color x:Key="LazadaBrandDark">#D01142</Color>
    
    <Color x:Key="LazadaCanvas">#F8F9FA</Color>
    <Color x:Key="LazadaSurface">#FFFFFF</Color>
    <Color x:Key="LazadaOverlay">#F1F5F9</Color>
    
    <Color x:Key="LazadaTextPrimary">#1F2937</Color>
    <Color x:Key="LazadaTextSecondary">#4B5563</Color>
    <Color x:Key="LazadaTextMuted">#9CA3AF</Color>
    
    <Color x:Key="LazadaBorder">#E5E7EB</Color>
    <Color x:Key="LazadaBorderStrong">#D1D5DB</Color>
    
    <!-- Spacing & Radius -->
    <x:Double x:Key="RadiusXS">4</x:Double>
    <x:Double x:Key="RadiusSM">6</x:Double>
    <x:Double x:Key="RadiusMD">10</x:Double>
    <x:Double x:Key="RadiusLG">14</x:Double>
    <x:Double x:Key="RadiusXL">18</x:Double>
    <x:Double x:Key="RadiusFull">9999</x:Double>

    <!-- Typography Scale -->
    <x:Double x:Key="TextXS">11</x:Double>
    <x:Double x:Key="TextSM">13</x:Double>
    <x:Double x:Key="TextBase">15</x:Double>
    <x:Double x:Key="TextMD">17</x:Double>
    <x:Double x:Key="TextLG">20</x:Double>
    <x:Double x:Key="TextXL">24</x:Double>
    <x:Double x:Key="Text2XL">30</x:Double>
    <x:Double x:Key="Text3XL">40</x:Double>

    <!-- Base Styles following Policy -->
    <Style x:Key="LazadaCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource LazadaSurface}" />
        <Setter Property="Stroke" Value="{StaticResource LazadaBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="15" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
    </Style>

    <Style x:Key="LazadaBadgeStyle" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource TextXS}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BackgroundColor" Value="{StaticResource LazadaBrand}" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

</ResourceDictionary>
